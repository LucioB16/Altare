---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { events } = getWeddingData();
const celebration = events.celebration;
import Divider from "./Divider.astro";
import SectionIcon from "./SectionIcon.astro";
---

<Divider type="small" />
<section class="section py-24 bg-[#EEF0EC]">
  <div class="section__inner container mx-auto px-6 text-center max-w-5xl">

    <SectionIcon name="celebration" />

    <p class="text-xs md:text-sm tracking-[0.4em] font-sans uppercase text-primary opacity-80 mb-4">
        A festejar
    </p>

    <h2 class="text-4xl md:text-5xl font-display text-primary tracking-wide mb-10" style="font-family: var(--font-display);">
        {celebration.kindLabel}
    </h2>

    <div class="border border-gray-200 bg-white p-8 md:p-12 max-w-3xl mx-auto shadow-sm flex flex-col items-center">
        
        <div class="text-3xl text-primary mb-4">
            <Icon name="lucide:glass-water" />
        </div>
        <div class="text-xl md:text-2xl text-primary mb-8" style="font-family: var(--font-display);">
            {celebration.timeDisplay}
        </div>
        
        <div class="mb-8 font-sans text-gray-600">
            <h3 class="text-lg font-bold text-primary mb-2 uppercase tracking-wide">{celebration.venueName}</h3>
            {celebration.addressLines.map(line => (
                <p>{line}</p>
            ))}
        </div>
        
        <a 
            href={celebration.mapsUrl} 
            target="_blank" 
            rel="noopener noreferrer"
            class="bg-primary text-white tracking-[0.2em] uppercase text-sm font-semibold py-4 px-8 hover:bg-opacity-90 transition-colors"
        >
            CÓMO LLEGAR
        </a>
    </div>
  </div>
</section>
