---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";
const data = getWeddingData();
const info = data.usefulInfo;
---

<section class="section">
  <div class="section__inner container mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-center mb-10">{info.title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {info.items.filter(i => i.enabled).map((item) => (
        <div class="flex items-start space-x-4">
          <div class="text-2xl text-primary">
            <Icon name={item.icon} />
          </div>
          <div>
            <h3 class="font-semibold text-lg">{item.title}</h3>
            <p class="text-gray-600">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
