---
import { getWeddingData } from "../data/weddingData";
import Icon from "./Icon.astro";

const { rsvp } = getWeddingData();
import Divider from "./Divider.astro";
import SectionIcon from "./SectionIcon.astro";
---

<Divider type="large" />
<section class="section py-24 bg-[#EEF0EC]">
    <div class="section__inner container mx-auto px-6 text-center max-w-5xl">
        <SectionIcon name="calendar" />

        <p
            class="text-xs md:text-sm tracking-[0.4em] font-sans uppercase text-primary opacity-80 mb-4"
        >
            ¿Nos acompañas?
        </p>

        <h2
            class="text-4xl md:text-5xl font-display text-primary tracking-wide mb-10"
            style="font-family: var(--font-display);"
        >
            Confirmación de asistencia
        </h2>

        <div
            class="border border-gray-200 bg-white p-8 md:p-12 max-w-3xl mx-auto shadow-sm flex flex-col items-center"
        >
            <p class="text-lg text-gray-600 mb-8 font-sans leading-relaxed">
                {rsvp.text}
            </p>

            {
                rsvp.deadline && (
                    <p class="text-sm font-semibold text-primary mb-8 tracking-[0.2em] uppercase">
                        FECHA LÍMITE: {rsvp.deadline}
                    </p>
                )
            }

            {
                rsvp.link?.enabled && rsvp.link.url && (
                    <a
                        href={rsvp.link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="bg-primary text-white tracking-[0.2em] uppercase text-sm font-semibold py-4 px-8 hover:bg-opacity-90 transition-colors w-full sm:w-auto"
                    >
                        {rsvp.link.label || "CONFIRMAR ASISTENCIA"}
                    </a>
                )
            }
        </div>
    </div>
</section>
