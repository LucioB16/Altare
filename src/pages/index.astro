---
import Layout from "../layouts/Layout.astro";
import { getWeddingData } from "../data/weddingData";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Count from "../components/Count.astro";
import Ceremony from "../components/Ceremony.astro";
import Celebration from "../components/Celebration.astro";
import Socials from "../components/Socials.astro";
import Gifts from "../components/Gifts.astro";
import DressCode from "../components/DressCode.astro";
import RSVP from "../components/RSVP.astro";
import Calendar from "../components/Calendar.astro";
import Playlist from "../components/Playlist.astro";
import UsefulInfo from "../components/UsefulInfo.astro";

const data = getWeddingData();
const showAllSectionsInDemo = data.demo?.themeSwitcher === true;
const showReligiousCeremony = Boolean(
  data.events.religiousCeremony &&
    (data.events.religiousCeremony.enabled || showAllSectionsInDemo)
);
---

<Layout
  title={data.site.pageTitle}
  description={data.site.meta.description}
  ogImage={data.site.meta.ogImage}
  data={data}
>
  {data.hero.enabled && <Hero data={data} />}
  {data.sections.countdown.enabled && <Count data={data} />}
  {
    showReligiousCeremony && (
      <Ceremony
        eventKey="religiousCeremony"
        dividerType="flower"
        bgClass="bg-surface"
        forceVisible={showAllSectionsInDemo}
        data={data}
      />
    )
  }
  {
    data.events.ceremony.enabled && (
      <Ceremony
        eventKey="ceremony"
        dividerType="small"
        bgClass="bg-surface-alt"
        data={data}
      />
    )
  }
  {data.events.celebration.enabled && <Celebration data={data} />}
  {data.sections.story.enabled && <Story data={data} />}
  {data.sections.socials.enabled && <Socials data={data} />}
  {data.sections.gifts.enabled && <Gifts data={data} />}
  {data.sections.dressCode.enabled && <DressCode data={data} />}
  {data.sections.rsvp.enabled && <RSVP data={data} />}
  {data.sections.calendar.enabled && <Calendar data={data} />}
  {data.sections.playlist.enabled && <Playlist data={data} />}
  {data.sections.usefulInfo.enabled && <UsefulInfo data={data} />}
</Layout>